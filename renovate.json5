{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "github>aquaproj/aqua-renovate-config#2.8.0"
  ],
  "packageRules": [
    {
      // go.mod の go directive
      "groupName": "golang",
      "matchManagers": ["gomod"],
      "matchDepNames": ["go"],
      "matchDepTypes": ["golang"],
      "rangeStrategy": "bump",
      "enabled": true,
    },
    {
      // Dockerfile の golang イメージ, CircleCI の cimg/go イメージ
      "groupName": "golang",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["golang", "cimg/go"],
    },
    {
      // GitHub Actions の setup-go (go-version)
      "groupName": "golang",
      "matchManagers": ["github-actions"],
      "matchDepNames": ["go"],
    },
    {
      // aqua.yaml の golang/go (aqua-renovate-config の custom regex manager 経由)
      "groupName": "golang",
      "matchDatasources": ["github-tags"],
      "matchDepNames": ["golang/go"],
      "matchFileNames": ["aqua.yaml"],
    }
  ]
}
